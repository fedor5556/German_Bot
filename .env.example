# German bot secrets -- copy to .env and fill in. NEVER commit the real .env.
# Delivered to the server out-of-band (bus bot / Backblaze), never via Git.

# From @BotFather (/newbot)
TELEGRAM_TOKEN=

# From https://aistudio.google.com -> Get API key (free tier)
GEMINI_API_KEY=

# Your numeric Telegram user ID (e.g. via @userinfobot). Comma-separated for
# multiple. This is BOTH the auth gate and the daily-push target. If empty, the
# bot refuses everyone (fail-closed) and will not start.
OWNER_TELEGRAM_ID=

# You and the host PC are both in Cyprus. Leave as-is unless that changes.
PUSH_TZ=Europe/Nicosia

# Optional: override the Gemini model (defaults to gemini-3.5-flash).
# GEMINI_MODEL=gemini-3.5-flash
